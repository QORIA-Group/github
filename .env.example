# =============================================================================
# QORIA OS - Environment Configuration Template
# =============================================================================
# IMPORTANT: Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Application ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# --- PostgreSQL (Relational Data Hub) ---
DATABASE_URL=postgresql://qoria_user:password@localhost:5432/qoria_os?schema=public

# --- Neo4j (Knowledge Graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- JWT & Auth ---
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=3600

# --- KYRA Cognitive Engine ---
KYRA_CACHE_TTL=300
KYRA_LLM_ENDPOINT=https://api.mistral.ai/v1
KYRA_LLM_API_KEY=your-llm-api-key

# --- PulseFlow ---
PULSEFLOW_CHANNEL=pulseflow_events
PULSEFLOW_OUTBOX_POLL_INTERVAL=1000
